# Base storage path used to build the research paper download directory.
AGENTIC_SYSTEM_PATH=/opt/agentic/agentic-system

# Optional Semantic Scholar API key. Strongly recommended to avoid low anonymous rate limits.
SEMANTIC_SCHOLAR_API_KEY=

# HTTP retry policy for upstream paper APIs.
RESEARCH_PAPER_HTTP_MAX_RETRIES=3
RESEARCH_PAPER_RETRY_DELAY_SECONDS=2

# arXiv request pacing. Keep this conservative to reduce 429 responses.
ARXIV_MIN_INTERVAL_SECONDS=3
